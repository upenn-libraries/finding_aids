<%# Overrides component from Blacklight 9.0.0 to render a compact search bar that sits
    inside the design system header (see HeaderComponent's slot="end"). %>
<%= tag.div class: 'd-flex align-items-center gap-3', role: 'navigation', aria: { label: t('blacklight.search.header') } do %>
  <div class="flex-grow-1">
    <%= search_bar %>
  </div>
<% end %>
