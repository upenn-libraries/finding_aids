<%# ============================================================================
    HOMEPAGE — UI ported from the finding-aids-prototype (Eleventy mockup).

    Collection guides data is loaded by CatalogController and rendered by
    Homepage::CollectionGuideCardsComponent.

    The "A regional partnership" section (repositories + map) lives in the site-wide
    pre-footer band: app/views/shared/_regional_partnership.html.erb.
    ============================================================================ %>

<%# --- Hero (replaces the standard header on the homepage) ------------------- %>
<% content_for(:header) do %>
  <%= render HeaderHeroComponent.new(blacklight_config: blacklight_config) do |hero| %>
    <% hero.with_picture do %>
      <picture hero="art-direction">
        <%= image_tag 'moelis-reading-room.jpg', alt: 'An archival reading room' %>
      </picture>
    <% end %>
    <% hero.with_heading do %>
      <h1 hero="heading">Stories held in archives</h1>
    <% end %>
    <% hero.with_subheading do %>
      <p hero="sub-heading">Find your way into the primary sources held by archives in the Philadelphia area.</p>
    <% end %>
  <% end %>
<% end %>

<%# --- Home sections --------------------------------------------------------- %>
<div class="fa-home-sections">
  <%= render Homepage::CollectionGuideCardsComponent.new(guides: @homepage_guides) %>
</div>
