<h1>Collection Guides</h1>

<p class="text-muted mb-3">Picks appear first in the &ldquo;Collection guides&rdquo; section on the homepage. Remaining slots are filled automatically from the archive.</p>

<div class="d-flex justify-content-end">
  <div class="btn-group mb-3">
    <%= link_to t('admin.actions.create'), new_collection_guide_path, class: 'btn btn-outline-dark' %>
  </div>
</div>

<% if @guides.empty? %>
  <p>No picks yet. The homepage will show 8 guides chosen automatically from the archive.</p>
<% else %>
  <table class="table table-striped">
    <thead>
    <tr>
      <th scope="col">Title</th>
      <th scope="col">Repository</th>
      <th scope="col"></th>
    </tr>
    </thead>
    <tbody>
    <% @guides.each do |guide| %>
      <tr>
        <td><%= link_to guide.title, edit_collection_guide_path(guide) %></td>
        <td><%= guide.repository %></td>
        <td><%= button_to t('admin.actions.destroy'), collection_guide_path(guide), method: :delete, class: 'btn btn-sm btn-outline-danger', form: { data: { turbo_confirm: 'Remove this pick?' } } %></td>
      </tr>
    <% end %>
    </tbody>
  </table>
<% end %>
