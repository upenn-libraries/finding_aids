<h1>Featured Collections</h1>

<div class="d-flex justify-content-end">
  <div class="btn-group mb-3">
    <%= link_to t('admin.actions.create'), new_featured_collection_path, class: 'btn btn-outline-dark' %>
  </div>
</div>

<% if @collections.empty? %>
  <p>No featured collections yet.</p>
<% else %>
  <p class="text-muted small mb-2">Drag rows to reorder.</p>
  <table class="table table-striped" data-controller="sortable" data-sortable-url-value="<%= reorder_featured_collections_path %>">
    <thead>
    <tr>
      <th scope="col" style="width: 2rem;"></th>
      <th scope="col">Title</th>
      <th scope="col">Repository</th>
      <th scope="col">Active</th>
      <th scope="col"></th>
    </tr>
    </thead>
    <tbody data-sortable-target="list">
    <% @collections.each do |collection| %>
      <tr data-id="<%= collection.id %>" class="sortable-item">
        <td class="text-muted" style="cursor: grab;">⠿</td>
        <td><%= link_to collection.title, edit_featured_collection_path(collection) %></td>
        <td><%= collection.repository %></td>
        <td><%= collection.active? ? 'Yes' : 'No' %></td>
        <td><%= button_to t('admin.actions.destroy'), featured_collection_path(collection), method: :delete, class: 'btn btn-sm btn-outline-danger', form: { data: { turbo_confirm: 'Remove this featured collection?' } } %></td>
      </tr>
    <% end %>
    </tbody>
  </table>
<% end %>
