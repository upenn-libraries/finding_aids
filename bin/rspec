#!/bin/bash
# Run RSpec tests inside the Rails container.
# Usage: bin/rspec [path]
#   bin/rspec                    # all specs
#   bin/rspec spec/services/     # specific directory or file

set -euo pipefail

CONTAINER=$(docker exec finding-aids docker ps \
  --filter "name=fad_finding_aid_discovery" -q | head -1)

[ -n "$CONTAINER" ] || { echo "No Rails container found" >&2; exit 1; }

exec docker exec finding-aids docker exec -e RAILS_ENV=test "$CONTAINER" \
  bundle exec rspec "$@"
