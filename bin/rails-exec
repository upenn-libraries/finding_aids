#!/bin/bash
# Execute a command inside the most recent Rails app container.
# For agent/non-interactive use — no TTY flags.
# Usage: bin/rails-exec <command>
#   bin/rails-exec bundle exec rspec spec/helpers/
#   bin/rails-exec rails runner 'puts User.count'
#   bin/rails-exec bash

set -euo pipefail

# Find the most recent Rails app container inside the dind container
CONTAINER=$(docker exec finding-aids docker ps \
  --filter "name=fad_finding_aid_discovery" \
  --format "{{.CreatedAt}}\t{{.ID}}" \
  --no-trunc 2>/dev/null \
  | sort -r | head -1 | cut -f2)

if [ -z "$CONTAINER" ]; then
  echo "Error: No Rails app container found. Is the app running?" >&2
  exit 1
fi

exec docker exec finding-aids docker exec "$CONTAINER" "$@"
