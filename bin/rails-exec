#!/bin/bash
# Execute a command inside the most recent Rails app container.
# Usage: bin/rails-exec <command>
#   bin/rails-exec bundle exec rspec spec/helpers/
#   bin/rails-exec RAILS_ENV=test bundle exec rspec spec/
#   bin/rails-exec bash

set -euo pipefail

CONTAINER=$(docker exec finding-aids docker ps \
  --filter "name=fad_finding_aid_discovery" -q | head -1)

if [ -z "$CONTAINER" ]; then
  echo "Error: No Rails app container found." >&2
  exit 1
fi

# Shell-escape each argument so sh -c preserves boundaries and
# handles KEY=VALUE env var prefixes naturally.
cmd=""
for a in "$@"; do
  cmd="$cmd $(printf '%q' "$a")"
done

exec docker exec finding-aids docker exec "$CONTAINER" sh -c "$cmd"
