#!/bin/bash
# Execute a command inside the most recent Rails app container.
# For agent/non-interactive use — no TTY flags.
# Usage: bin/rails-exec <command>
#   bin/rails-exec bundle exec rspec spec/helpers/
#   bin/rails-exec rails runner 'puts User.count'
#   bin/rails-exec bash

set -euo pipefail

# Find the most recent Rails app container inside the dind container
CONTAINER=$(docker exec finding-aids docker ps \
  --filter "name=fad_finding_aid_discovery" \
  --format "{{.CreatedAt}}\t{{.ID}}" \
  --no-trunc 2>/dev/null \
  | sort -r | head -1 | cut -f2)

if [ -z "$CONTAINER" ]; then
  echo "Error: No Rails app container found. Is the app running?" >&2
  exit 1
fi

# Extract leading KEY=VALUE pairs into -e flags; rest pass through as args
ENV_FLAGS=()
CMD_ARGS=()
seeking_env=true
for arg in "$@"; do
  if [ "$seeking_env" = true ] && [[ "$arg" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]]; then
    ENV_FLAGS+=(-e "$arg")
  else
    seeking_env=false
    CMD_ARGS+=("$arg")
  fi
done

if [ ${#CMD_ARGS[@]} -eq 0 ]; then
  echo "Error: No command specified" >&2
  exit 1
fi

# bash 3.2 (macOS default) treats empty arrays as unbound under set -u
# so we use the "${array[@]+...}" idiom for safe expansion
exec docker exec finding-aids docker exec ${ENV_FLAGS[@]+"${ENV_FLAGS[@]}"} "$CONTAINER" "${CMD_ARGS[@]}"
